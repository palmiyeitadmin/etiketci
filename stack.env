# Portainer repository deployment variables
# Update these values before deploying the stack in Portainer.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=plms
DB_PORT=5433
DB_VOLUME_NAME=etiket-editor-db-data

ASPNETCORE_ENVIRONMENT=Production
BACKEND_PORT=5001
JWT_KEY=change-me-jwt-signing-key-with-at-least-32-characters
JWT_ISSUER=PLMS_API
APP_PUBLIC_ORIGIN=http://192.168.0.99:3004
API_PUBLIC_ORIGIN=http://192.168.0.99:5001
SEED_ADMIN_EMAIL=admin@plms.local
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_ADMIN_FORCE_RESET_PASSWORD=true

FRONTEND_PORT=3004
NEXTAUTH_SECRET=change-me-nextauth-secret-with-at-least-32-characters
NEXT_PUBLIC_EDITOR_ENGINE=konva
