# Local Development Variables

# -----------------
# FRONTEND VARIABLES (Copy to src/frontend/.env.local)
# -----------------
NEXT_PUBLIC_API_URL=https://localhost:7001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=changeme_local_secret
AZURE_AD_CLIENT_ID=placeholder_entra_client_id
AZURE_AD_TENANT_ID=placeholder_entra_tenant_id

# -----------------
# BACKEND VARIABLES (Set via User Secrets or appsettings.Development.json)
# -----------------
# ConnectionStrings:DefaultConnection=Host=localhost;Database=plms;Username=postgres;Password=localpass
# AzureAd:TenantId=placeholder_entra_tenant_id
# AzureAd:ClientId=placeholder_backend_client_id
