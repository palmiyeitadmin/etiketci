# Local development variables

# Frontend local variables (copy to src/frontend/.env.local)
NEXT_PUBLIC_API_URL=https://localhost:7001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=changeme_local_secret
AZURE_AD_CLIENT_ID=placeholder_entra_client_id
AZURE_AD_TENANT_ID=placeholder_entra_tenant_id

# Backend local variables (set via user secrets or appsettings.Development.json)
# ConnectionStrings:DefaultConnection=Host=localhost;Database=plms;Username=postgres;Password=localpass
# AzureAd:TenantId=placeholder_entra_tenant_id
# AzureAd:ClientId=placeholder_backend_client_id

# Portainer repository deployment
# Copy stack.env in the repo root and replace every change-me / example value.
# docker-compose.yml reads these values during build and at runtime.
#
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=change-me-db-password
# POSTGRES_DB=plms
# DB_PORT=5433
# DB_VOLUME_NAME=etiket-editor-db-data
# ASPNETCORE_ENVIRONMENT=Production
# BACKEND_PORT=5001
# JWT_KEY=change-me-jwt-signing-key-with-at-least-32-characters
# JWT_ISSUER=PLMS_API
# APP_PUBLIC_ORIGIN=https://plms.example.com
# API_PUBLIC_ORIGIN=https://api.plms.example.com
# SEED_ADMIN_EMAIL=admin@plms.local
# SEED_ADMIN_PASSWORD=change-me-admin-password
# SEED_ADMIN_FORCE_RESET_PASSWORD=true
# FRONTEND_PORT=3000
# NEXTAUTH_SECRET=change-me-nextauth-secret-with-at-least-32-characters
# NEXT_PUBLIC_EDITOR_ENGINE=konva
